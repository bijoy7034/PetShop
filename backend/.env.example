MODE=development
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

MONGO_URI=mongodb://localhost:27017
DB_NAME=petshop
MONGO_MAX_POOL_SIZE=50
MONGO_MIN_POOL_SIZE=5

CORS_ALLOW_ORIGINS=["http://localhost:5173"]

JWT_SECRET=replace-me-with-a-long-random-string
JWT_ALGORITHM=HS256

ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=14

# In prod set COOKIE_SECURE=true (requires HTTPS) and pin COOKIE_DOMAIN.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=petshop.yourdomain.com

# First-boot admin. If a user with ADMIN_EMAIL does not exist, the lifespan
# hook creates one with ADMIN_PASSWORD and forces a password change on first
# login. Leave empty in production once the account is provisioned.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=
